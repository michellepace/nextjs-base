{
  "name": "nextjs-base",
  "version": "0.1.0",
  "private": true,
  "markdownlint-cli2": {
    "config": ".markdownlint.yaml",
    "ignores": [
      "node_modules",
      ".next",
      "dist",
      "build"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --write",
    "type-check": "tsc --noEmit",
    "lint:md": "markdownlint-cli2 --fix \"**/*.md\"",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "lefthook": "^2.0.2",
    "markdownlint-cli2": "^0.18.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
